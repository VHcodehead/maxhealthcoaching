# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:port/dbname

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-here

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_BASIC=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ELITE=price_xxx

# OpenAI
OPENAI_API_KEY=sk-xxx

# USDA FoodData Central (free key from https://fdc.nal.usda.gov/api-key-signup.html)
USDA_API_KEY=your_usda_api_key_here

# File Storage (Railway Volume)
UPLOAD_DIR=/data/uploads

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Unified Coaching Hub — read bridge to MyPocketCoach backend (Phase 0, ADR 008)
# COACHING_BACKEND_URL: base URL of my-coach-backend (Railway). No trailing slash.
# COACHING_EXPORT_SECRET: long high-entropy shared secret (≥32 chars). MUST match
#   the same env var set on my-coach-backend. Generate with: openssl rand -hex 32
COACHING_BACKEND_URL=https://your-backend.up.railway.app
COACHING_EXPORT_SECRET=replace-with-openssl-rand-hex-32
